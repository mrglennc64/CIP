# Copy this to .env.local and fill in real values.
# .env.local is gitignored.

# Password to access /ops/* internal tools.
OPS_PASSWORD=change-me-please

# Random secret used to sign the ops auth cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPS_AUTH_SECRET=replace-with-32-bytes-of-hex

# Optional. If set, the "social" job uses Claude Haiku to draft posts.
# Without this, social falls back to templated drafts.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional. If set, the PDF generator pipes raw scanner findings through
# Gemini to produce Carina-tone rewrites. Without this, the PDF uses the
# template-based regex rewrites (cosmetic only).
# Get one at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
